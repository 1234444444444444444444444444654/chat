# Copia este archivo como .env.local y rellena los valores

# MongoDB - consíguelo en mongodb.com/atlas (gratis)
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/chatapp

# NextAuth - genera uno random en: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=pon_aqui_una_clave_random_muy_larga
NEXTAUTH_URL=http://localhost:3000

# Anthropic - consíguelo en console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (opcional) - consíguelo en platform.openai.com
OPENAI_API_KEY=sk-...
